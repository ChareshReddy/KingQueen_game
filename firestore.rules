// NOTE: Since this is a client-authoritative game without a dedicated backend server,
// certain field updates (like scores and roles) are initiated by clients. For complete
// security against malicious client modification, score/role mutation logic should be
// moved server-side (e.g., using Cloud Functions). The constraints below provide a
// partial mitigation by restricting player updates to their own documents and preventing
// direct self-modification of sensitive fields (totalScore, currentRole).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to determine if a room is stale / expired
    function isRoomStale(roomData) {
      return roomData.containsKey('createdAt') && (
        roomData.status == 'finished' 
          ? request.time > timestamp.value(roomData.createdAt) + duration.value(7, 'd')
          : request.time > timestamp.value(roomData.createdAt) + duration.value(24, 'h')
      );
    }

    // Users rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalScore', 'wins'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalScore', 'wins'])
      );
    }

    // Rooms rules
    match /rooms/{roomId} {
      allow create: if isAuthenticated();
      // Allow read if user is authenticated and the room doesn't exist yet (for uniqueness check), is waiting (for joining), they are in the room, or it is stale (for cleanups)
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.status == 'waiting' ||
        request.auth.uid in resource.data.playerIds || 
        request.auth.uid == resource.data.hostId ||
        isRoomStale(resource.data)
      );
      // Allow update if the room is in waiting status (for joining) or the user is in the room
      allow update: if isAuthenticated() && (
        resource.data.status == 'waiting' ||
        request.auth.uid in resource.data.playerIds || 
        request.auth.uid == resource.data.hostId
      );
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.hostId ||
        isRoomStale(resource.data)
      );

      // Players subcollection
      match /players/{playerId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (
          get(/databases/$(database)/documents/rooms/$(roomId)).data.status == 'waiting' ||
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.playerIds ||
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId
        );
        allow update: if isAuthenticated() && (
          // Host can modify anything (initial role deal, resets, etc.)
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId ||
          // Doc owner can update their own metadata (ready status, online status, name) but NOT totalScore or currentRole
          (request.auth.uid == playerId && 
           !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalScore', 'currentRole'])) ||
          // Any player in the room can update player documents, but ONLY to swap currentRole
          (request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.playerIds &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentRole']))
        );
        allow delete: if isAuthenticated() && (
          request.auth.uid == playerId ||
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId ||
          isRoomStale(get(/databases/$(database)/documents/rooms/$(roomId)).data)
        );
      }

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.playerIds
        );
        allow delete: if isAuthenticated() && (
          request.auth.uid == get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId ||
          request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.playerIds ||
          isRoomStale(get(/databases/$(database)/documents/rooms/$(roomId)).data)
        );
      }
    }
  }
}
